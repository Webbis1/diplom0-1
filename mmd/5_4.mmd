flowchart TD
    subgraph MainLoop["Главный цикл событий"]
        direction TB
        MGR["Модули управления активами"]
        EX_OBS["Наблюдатели рыночных данных"]
        CONN_W["Сторожевые таймеры соединений"]
        AN_Q["Очередь задач аналитического ядра\n(Дедупликация)"]
    end

    subgraph WorkerPool["Изолированный пул исполнителей"]
        direction TB
